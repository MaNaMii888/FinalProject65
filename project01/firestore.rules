rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==========================================
    // 1. users collection
    // ==========================================
    match /users/{userId} {
      // Anyone authenticated can read user profiles (so they can see who posted an item)
      allow read: if isAuthenticated();
      
      // Users can only create, update, or delete their own profile document
      allow create, update, delete: if isOwner(userId);
    }

    // ==========================================
    // 2. lost_found_items collection
    // ==========================================
    match /lost_found_items/{itemId} {
      // Anyone authenticated can view the feed of items
      allow read: if isAuthenticated();
      
      // Creating an item: The userId field in the document MUST match the creator's UID
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Updating or Deleting an item: Only the original creator (owner) can modify or delete it
      allow update, delete: if isOwner(resource.data.userId);
    }

    // ==========================================
    // 3. archived_items collection
    // ==========================================
    match /archived_items/{itemId} {
      // Anyone authenticated can read archived items (for reference in history)
      allow read: if isAuthenticated();
      
      // Creating an archived item: the userId must match the creator's UID
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Updating archived items is not allowed (it's permanent history)
      allow update: if false;

      // Deleting archived items (only owner can delete permanently)
      allow delete: if isOwner(resource.data.userId);
    }

    // ==========================================
    // 4. notifications collection
    // ==========================================
    match /notifications/{notificationId} {
      // Users can only read their own notifications (where userId matches their UID)
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Any authenticated user can CREATE a notification (e.g. when matching an item or sending a contact request)
      allow create: if isAuthenticated();
      
      // Only the recipient (userId) can modify their notifications (e.g. mark as read) or delete them
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==========================================
    // 5. device_tokens collection (Push Notifications)
    // ==========================================
    match /device_tokens/{tokenId} {
      // Users can only read, create, update, delete their own token records
      allow read, create, update, delete: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    // ==========================================
    // 6. chats collection (In-App Chat)
    // ==========================================
    match /chats/{chatId} {
      // ให้อ่าน/เขียน/ลบ เฉพาะคนที่อยู่ในรายชื่อ participants ของห้องแชทนี้
      allow read, update, delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
      // ให้สร้างห้องได้ถ้าตัวเองเป็น 1 ใน participants
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      // Sub-collection รูปแบบข้อความ
      match /messages/{messageId} {
        // ให้จัดการข้อความได้ ถ้าเราเป็น 1 ในคนที่มีสิทธิ์เข้าห้อง (แอบตรวจสอบจากปกห้องแชท)
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ==========================================
    // 7. handover_transactions collection (QR Handover)
    // ==========================================
    match /handover_transactions/{transactionId} {
      // ผู้สร้าง (senderId) หรือผู้รับ (receiverId) สามารถอ่านและอัปเดตได้
      allow read, update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      
      // ผู้สร้าง (คนที่สร้าง QR) สามารถสร้างได้
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
    }
  }
}
